{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jzod.dev/schema/jzod-0.0.0.schema.json",
  "title": "JZOD 0.0.0",
  "description": "Open astrological chart interchange format",
  "type": "object",
  "required": ["version", "charts"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "charts": { "type": "array", "items": { "$ref": "#/$defs/Chart" } }
  },
  "$defs": {
    "Sign": {
      "type": "string",
      "enum": ["aries","taurus","gemini","cancer","leo","virgo",
               "libra","scorpio","sagittarius","capricorn","aquarius","pisces"]
    },
    "Position": {
      "type": "object",
      "required": ["ecliptic_longitude","sign","degree","minute","second"],
      "properties": {
        "ecliptic_longitude": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "sign":   { "$ref": "#/$defs/Sign" },
        "degree": { "type": "integer", "minimum": 0, "maximum": 29 },
        "minute": { "type": "integer", "minimum": 0, "maximum": 59 },
        "second": { "type": "integer", "minimum": 0, "maximum": 59 }
      }
    },
    "HouseCusp": {
      "type": "object",
      "required": ["longitude","sign","degree","minute","second"],
      "properties": {
        "longitude": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "sign":   { "$ref": "#/$defs/Sign" },
        "degree": { "type": "integer", "minimum": 0, "maximum": 29 },
        "minute": { "type": "integer", "minimum": 0, "maximum": 59 },
        "second": { "type": "integer", "minimum": 0, "maximum": 59 }
      }
    },
    "Body": {
      "type": "object",
      "required": ["id","ecliptic_longitude","sign","degree","minute","second",
                   "ecliptic_latitude","daily_speed","retrograde"],
      "properties": {
        "id": { "type": "string" },
        "ecliptic_longitude": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "sign":   { "$ref": "#/$defs/Sign" },
        "degree": { "type": "integer", "minimum": 0, "maximum": 29 },
        "minute": { "type": "integer", "minimum": 0, "maximum": 59 },
        "second": { "type": "integer", "minimum": 0, "maximum": 59 },
        "ecliptic_latitude": { "type": "number" },
        "daily_speed": { "type": "number" },
        "retrograde": { "type": "boolean" },
        "distance_au": { "type": "number" },
        "house": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 1, "maximum": 12 }
        }
      }
    },
    "Angle": {
      "type": "object",
      "required": ["id","ecliptic_longitude","sign","degree","minute","second"],
      "properties": {
        "id": { "type": "string",
                "enum": ["ascendant","descendant","midheaven","imum_coeli"] },
        "ecliptic_longitude": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "sign":   { "$ref": "#/$defs/Sign" },
        "degree": { "type": "integer", "minimum": 0, "maximum": 29 },
        "minute": { "type": "integer", "minimum": 0, "maximum": 59 },
        "second": { "type": "integer", "minimum": 0, "maximum": 59 }
      }
    },
    "Point": {
      "type": "object",
      "required": ["id","ecliptic_longitude","sign","degree","minute","second","retrograde"],
      "properties": {
        "id": { "type": "string",
                "enum": ["vertex","anti_vertex","north_node_mean","north_node_true",
                         "south_node_mean","south_node_true","black_moon_lilith_mean",
                         "black_moon_lilith_true","priapus_mean","priapus_true"] },
        "ecliptic_longitude": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "sign":   { "$ref": "#/$defs/Sign" },
        "degree": { "type": "integer", "minimum": 0, "maximum": 29 },
        "minute": { "type": "integer", "minimum": 0, "maximum": 59 },
        "second": { "type": "integer", "minimum": 0, "maximum": 59 },
        "retrograde": { "type": "boolean" }
      }
    },
    "Lot": {
      "type": "object",
      "required": ["id","ecliptic_longitude","sign","degree","minute","second"],
      "properties": {
        "id": { "type": "string",
                "enum": ["lot_of_fortune","lot_of_spirit","lot_of_eros","lot_of_exaltation",
                         "lot_of_necessity","lot_of_courage","lot_of_victory","lot_of_nemesis"] },
        "ecliptic_longitude": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "sign":   { "$ref": "#/$defs/Sign" },
        "degree": { "type": "integer", "minimum": 0, "maximum": 29 },
        "minute": { "type": "integer", "minimum": 0, "maximum": 59 },
        "second": { "type": "integer", "minimum": 0, "maximum": 59 }
      }
    },
    "Placements": {
      "type": "object",
      "required": ["bodies"],
      "properties": {
        "bodies": { "type": "array", "items": { "$ref": "#/$defs/Body" } },
        "angles": { "type": "array", "items": { "$ref": "#/$defs/Angle" } },
        "points": { "type": "array", "items": { "$ref": "#/$defs/Point" } },
        "lots":   { "type": "array", "items": { "$ref": "#/$defs/Lot" } }
      }
    },
    "Datetime": {
      "type": "object",
      "required": ["year","month","day","hour","minute","second","utc_offset","unknown"],
      "properties": {
        "year":   { "type": "integer" },
        "month":  { "type": "integer", "minimum": 1, "maximum": 12 },
        "day":    { "type": "integer", "minimum": 1, "maximum": 31 },
        "hour":   { "type": "integer", "minimum": 0, "maximum": 23 },
        "minute": { "type": "integer", "minimum": 0, "maximum": 59 },
        "second": { "type": "integer", "minimum": 0, "maximum": 59 },
        "utc_offset": { "type": "string", "pattern": "^[+-][0-9]{2}:[0-9]{2}$" },
        "iana_tz": { "type": "string" },
        "unknown": { "type": "boolean" },
        "tod_method": { "type": "string", "enum": ["sunrise","chandra_lagna","noon"] }
      }
    },
    "Location": {
      "type": "object",
      "properties": {
        "name":      { "type": "string" },
        "latitude":  { "type": "number", "minimum": -90,  "maximum": 90  },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "Zodiac": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "enum": ["tropical","sidereal","draconic"] },
        "ayanamsha": { "type": "string" },
        "frame": { "type": "string", "enum": ["mean","true"] },
        "node":  { "type": "string", "enum": ["mean","true"], "description": "draconic node choice; absent = unrecorded" }
      }
    },
    "Ephemeris": {
      "type": "object",
      "required": ["source","calculated_at"],
      "properties": {
        "source": { "type": "string" },
        "calculated_at": { "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
        "jd_ut": { "type": "number" },
        "jd_tt": { "type": "number" }
      }
    },
    "Chart": {
      "type": "object",
      "required": ["uid","type","birth","zodiac","coordinate_system","ephemeris",
                   "placements","lunar_phase"],
      "properties": {
        "uid":  { "type": "string" },
        "type": { "type": "string",
                  "enum": ["radix","event","horary","election","decumbiture","mundane",
                           "transit","solar_return","lunar_return","secondary_progression",
                           "tertiary_progression","solar_arc","relocated","composite","chart"] },
        "name": {
          "type": "object",
          "required": ["display"],
          "properties": {
            "display": { "type": "string" },
            "aliases": { "type": "array", "items": { "type": "string" } }
          }
        },
        "gender": { "type": "string" },
        "rodden_rating": { "type": "string" },
        "birth": {
          "type": "object",
          "required": ["datetime","location"],
          "properties": {
            "datetime": { "$ref": "#/$defs/Datetime" },
            "location": { "$ref": "#/$defs/Location" }
          }
        },
        "zodiac": { "$ref": "#/$defs/Zodiac" },
        "coordinate_system": { "type": "string",
                               "enum": ["geocentric","topocentric","heliocentric"] },
        "sect": { "type": "string", "enum": ["diurnal","nocturnal","unknown"] },
        "ephemeris": { "$ref": "#/$defs/Ephemeris" },
        "placements": { "$ref": "#/$defs/Placements" },
        "houses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/HouseCusp" }
          }
        },
        "lunar_phase": { "type": ["object","null"] },
        "nested": { "type": "array", "items": { "$ref": "#/$defs/Chart" } }
      }
    }
  }
}
